{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "100000",
    "ANTHROPIC_BASE_URL": "https://gateway.tail8bd569.ts.net/anthropic",
    "MECHANISM_TOKEN": "not-used-but-required",
    "CLAUDE_ENV_FILE": "/Users/jefferyharrell/.claude/env.sh"
  },
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": [
      "/Users/jefferyharrell/Alpha"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "timestamp",
            "input": {
              "session_id": "${session_id}"
            }
          },
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "memories",
            "input": {
              "prompt": "${prompt}",
              "session_id": "${session_id}"
            }
          },
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "anamneses",
            "input": {
              "prompt": "${prompt}",
              "session_id": "${session_id}"
            }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "reflection",
            "input": {
              "session_id": "${session_id}",
              "stop_hook_active": "${stop_hook_active}"
            }
          }
        ]
      }
    ]
  },
  "agent": "Alpha",
  "autoMemoryEnabled": false,
  "skipAutoPermissionPrompt": true,
  "showThinkingSummaries": true
}