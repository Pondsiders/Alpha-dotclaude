{
  "agent": "Alpha",
  "env": {
    "ENABLE_TOOL_SEARCH": "false",
    "MAX_MCP_OUTPUT_TOKENS": 100000
  },
  "showThinkingSummaries": true,
  "autoMemoryEnabled": false,
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:8000/hooks/timestamp"
          },
          {
            "type": "http",
            "url": "http://localhost:8000/hooks/memories"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:8000/hooks/reflection"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  }
}
