{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "100000",
    "ANTHROPIC_BASE_URL": "https://gateway.tail8bd569.ts.net/anthropic",
    "MECHANISM_TOKEN": "not-used-but-required",
    "CLAUDE_ENV_FILE": "/Users/jefferyharrell/.claude/env.sh"
  },
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": [
      "/Users/jefferyharrell/Alpha"
    ],
    "allow": [
      "Edit(~/.claude/alpha/**)",
      "Write(~/.claude/alpha/**)"
    ]
  },
  "autoMode": {
    "allow": [
      "Alpha's context directory: creating and editing files under ~/.claude/alpha/, and deleting individual files there, is the agent maintaining its own context and reference files (gazetteer, lexicon, household facts, open threads). These are reference data, not behavioral config, and such edits are intended and authorized — do not treat them as Self-Modification. This exception does NOT cover: a config-named path nested under the directory (settings*.json, .mcp.json, CLAUDE.md, or a hooks/, commands/, agents/, skills/, or rules/ subdir), which remains Self-Modification; any hard block such as data exfiltration or credential leakage; or recursive/unbounded deletion that could reach paths above ~/.claude/alpha/."
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "timestamp",
            "input": {
              "session_id": "${session_id}"
            }
          },
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "memories",
            "input": {
              "prompt": "${prompt}",
              "session_id": "${session_id}"
            }
          },
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "anamneses",
            "input": {
              "prompt": "${prompt}",
              "session_id": "${session_id}"
            }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "reflection",
            "input": {
              "session_id": "${session_id}",
              "stop_hook_active": "${stop_hook_active}"
            }
          }
        ]
      }
    ]
  },
  "agent": "Alpha",
  "autoMemoryEnabled": false,
  "skipAutoPermissionPrompt": true,
  "showThinkingSummaries": true
}