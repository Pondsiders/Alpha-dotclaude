{
  "agent": "Alpha",
  "model": "claude-opus-4-7[1m]",
  "env": {
    "ENABLE_TOOL_SEARCH": "false",
    "MAX_MCP_OUTPUT_TOKENS": 100000
  },
  "autoMemoryEnabled": false,
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "timestamp",
            "input": {}
          },
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "memories",
            "input": {
              "prompt": "${prompt}",
              "session_id": "${session_id}"
            }
          },
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "anamneses",
            "input": {
              "prompt": "${prompt}",
              "session_id": "${session_id}"
            }
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "mcp_tool",
            "server": "mechanism",
            "tool": "reflection",
            "input": {
              "session_id": "${session_id}",
              "stop_hook_active": "${stop_hook_active}"
            }
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  }
}
